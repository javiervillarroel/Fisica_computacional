# ==========================================
# (d) Medir el tiempo
# ==========================================

N_valores=np.array([4,5,6,7,8])

Tiempos_promedios_hamiltoniano=[]
Tiempos_promedios_diagonalizar=[]
promedio=20
for N_val in N_valores:

    
    muestras_hamiltoniano = np.zeros(promedio)
    muestras_diagonal = np.zeros(promedio)
    
    for i in range(promedio):
        # Medir tiempo de construir el hamiltoniano
        inicio_hamiltoniano = time.perf_counter() 
        H=construir_hamiltoniano_ising(N_val, J, B)
        muestras_hamiltoniano[i] = time.perf_counter() - inicio_hamiltoniano
        
       
        # Medir tiempo de diagonalizar
        inicio_diagonalizacion=time.perf_counter() 
        # np.linalg.eigh devuelve los valores propios y vectores propios de matrices Hermíticas
        valores_propios, vectores_propios = np.linalg.eigh(H)
        # La matriz P está formada por los vectores propios en las columnas
        P = vectores_propios
        # La matriz D es una matriz diagonal que contiene los valores propios
        D = np.diag(valores_propios)     
        muestras_diagonal[i]=time.perf_counter() - inicio_diagonalizacion
        
        

    # Calculamos los promedios de un valor de N específico
    promedio_H = np.mean(muestras_hamiltoniano)
    promedio_D = np.mean(muestras_diagonal)
    
    Tiempos_promedios_hamiltoniano.append(promedio_H)
    Tiempos_promedios_diagonalizar.append(promedio_D)
    
    # Calculamos el tiempo total de este N y lo imprimimos
    tiempo_total_N = promedio_H + promedio_D
    print(f"Medición para N = {N_val} completada. Tiempo total: {tiempo_total_N:.4f} segundos")

