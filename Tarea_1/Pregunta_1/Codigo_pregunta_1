# ==========================================
# (b) l Hamiltoniano del modelo de Ising transversal en función de (N, J, B)
# ==========================================
def construir_hamiltoniano_ising(N, J, B):

    I = np.array([[1, 0], [0, 1]]) #Matriz identidad
    sigma_x = np.array([[0, 1], [1, 0]]) #Matriz de pauli x
    sigma_z = np.array([[1, 0], [0, -1]]) #Matriz de pauli z
    
    # --- Inicialización del Hamiltoniano ---
    dim = 2**N
    H = np.zeros((dim, dim)) # Iniciamos un hamiltoniano vacio 
    
    # --- Sumatoria de Interacción J ---
    for i in range(N - 1):
        operador_j = 1 #Para iniciar o elemento neutro
        for j in range(N):
            if j == i or j == i + 1:
                operador_j = np.kron(operador_j, sigma_x) #Producto de kronecker
            else:
                operador_j = np.kron(operador_j, I)
        
        H += J * operador_j
        
    # --- Sumatoria del Campo Transversal B ---
    for i in range(N):
        operador_b = 1 #Para iniciar o elemento neutro
        for j in range(N):
            if j == i:
                operador_b = np.kron(operador_b, sigma_z)
            else:
                operador_b = np.kron(operador_b, I)
                
        H += B * operador_b
        
    return H

# ==========================================
# (c) scipy.linalg.expm
# ==========================================
def Estado_total_i(N):
    Estado_i = np.array([0, 1])

    Estado_total = Estado_i


    for _ in range(N - 1):
        Estado_total = np.kron(Estado_total, Estado_i)

    print(f"La dimensión del estado total es: {Estado_total.shape}")
    return Estado_total


def operador_evolucion(H,t_max,dt,h_bar):
    termino_e=(-1j*H*dt)/h_bar
    U=expm(termino_e)
    return U

N=4
